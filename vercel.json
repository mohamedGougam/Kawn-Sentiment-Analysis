{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend/index.py",
      "routePrefix": "/_/backend",
      "framework": "fastapi",
      "excludeFiles": ["frontend/**", "**/node_modules/**", "**/.next/**"]
    }
  }
}
